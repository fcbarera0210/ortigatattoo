---
import { resolveMapEmbedUrl, toGoogleMapsLink } from '../../lib/maps';

interface ScheduleDay {
  day: string;
  ranges: string[];
}

interface Props {
  schedule: ScheduleDay[];
  address?: string | null;
  mapsUrl?: string | null;
}

const { schedule, address, mapsUrl } = Astro.props;

const hasSchedule = schedule.length > 0;
const hasAddress = Boolean(address?.trim());
const showSection = hasSchedule || hasAddress;

const embedUrl = await resolveMapEmbedUrl(mapsUrl, address);
const externalMapLink = toGoogleMapsLink(mapsUrl, address);
const showMap = Boolean(embedUrl);
---

{
  showSection && (
    <section id="horarios" class="mx-auto max-w-6xl px-4 py-16 md:px-6">
      <div class="mb-8 border-b border-border pb-4">
        <p class="text-xs uppercase tracking-[0.2em] text-muted">Visitanos</p>
        <h2 class="mt-1 font-display text-3xl md:text-4xl">Horarios y ubicación</h2>
      </div>

      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        {hasSchedule && (
          <div class="order-2 lg:order-1">
            <h3 class="mb-4 text-sm uppercase tracking-[0.16em] text-muted">Horarios de atención</h3>
            <div class="card grid gap-4 sm:grid-cols-2">
              {schedule.map((s) => (
                <div>
                  <p class="font-heading text-base">{s.day}</p>
                  <ul class="mt-2 space-y-1">
                    {s.ranges.map((r) => (
                      <li class="text-sm text-muted">{r}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        )}

        {hasAddress && (
          <div
            class:list={[
              'order-1 flex flex-col',
              hasSchedule ? 'lg:order-2' : 'lg:col-span-2 lg:mx-auto lg:w-full lg:max-w-2xl',
            ]}
          >
            <h3 class="mb-4 text-sm uppercase tracking-[0.16em] text-muted">Dónde estamos</h3>
            <div class="card flex flex-col gap-4">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <p class="text-base leading-relaxed md:text-lg">{address}</p>
                {externalMapLink && (
                  <a
                    href={externalMapLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="shrink-0 text-xs uppercase tracking-[0.14em] text-muted transition-colors hover:text-ink"
                  >
                    Abrir en Maps ↗
                  </a>
                )}
              </div>

              {showMap && embedUrl && (
                <div class="aspect-video w-full overflow-hidden border border-border">
                  <iframe
                    src={embedUrl}
                    title={`Mapa: ${address}`}
                    referrerpolicy="no-referrer-when-downgrade"
                    class="h-full w-full"
                    allowfullscreen
                  />
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    </section>
  )
}
