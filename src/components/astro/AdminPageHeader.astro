---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-8 border-b border-border pb-4">
  <p class="text-xs uppercase tracking-[0.2em] text-muted">Panel admin</p>
  <h1 class="mt-1 font-display text-3xl md:text-4xl">{title}</h1>
  {subtitle && <p class="mt-2 text-sm text-muted">{subtitle}</p>}
</div>
