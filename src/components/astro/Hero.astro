---
interface Props {
  name: string;
  description: string;
}

const { name, description } = Astro.props;
---

<section class="relative overflow-hidden border-b border-border">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute left-1/2 top-1/2 h-[min(90vw,560px)] w-[min(90vw,560px)] -translate-x-1/2 -translate-y-1/2 rounded-full border border-border opacity-40"
    >
    </div>
    <div
      class="absolute left-1/2 top-1/2 h-[min(70vw,420px)] w-[min(70vw,420px)] -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed border-border opacity-30"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 py-24 text-center md:px-6 md:py-32">
    <p class="text-xs uppercase tracking-[0.3em] text-muted">Estudio de tatuajes · La Plata</p>
    <h1 class="mt-4 font-display text-5xl leading-[0.95] sm:text-6xl md:text-7xl">
      {name}
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-base text-muted md:text-lg">
      {description}
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/reservar" class="btn-primary">Reservar sesión</a>
      <a href="/disponibles" class="btn-secondary">Ver flashes</a>
    </div>
  </div>
</section>
