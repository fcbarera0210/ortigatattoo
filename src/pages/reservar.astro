---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BookingFlow } from '../components/react/BookingFlow';

export const prerender = false;

const flashId = Astro.url.searchParams.get('flashId') ?? undefined;
const serviceId = Astro.url.searchParams.get('serviceId') ?? undefined;
---

<BaseLayout title="Reservar — Ortiga Tattoo">
  <section class="mx-auto max-w-4xl px-4 py-12 md:px-6">
    <div class="mb-8 border-b border-border pb-4">
      <p class="section-eyebrow">Reservas</p>
      <h1 class="mt-1 font-display text-3xl tracking-[0.1em] md:text-4xl">Reservá tu sesión</h1>
      <div class="divider-crimson mt-4"></div>
      <p class="mt-4 text-sm text-muted">
        Elegí un servicio o un diseño flash, seleccioná fecha y hora, y completá tus datos. Tu
        reserva queda pendiente de confirmación.
      </p>
    </div>
    <BookingFlow initialFlashId={flashId} initialServiceId={serviceId} client:load />
  </section>
</BaseLayout>
