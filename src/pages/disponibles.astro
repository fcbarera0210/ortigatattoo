---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FlashCatalog } from '../components/react/FlashCatalog';

export const prerender = false;
---

<BaseLayout title="Diseños disponibles — Ortiga Tattoo">
  <section class="mx-auto max-w-6xl px-4 py-12 md:px-6">
    <div class="mb-8 border-b border-border pb-4">
      <p class="text-xs uppercase tracking-[0.2em] text-muted">Flash</p>
      <h1 class="mt-1 font-display text-3xl md:text-4xl">Diseños disponibles</h1>
      <p class="mt-2 text-sm text-muted">
        Elegí un flash y reservá directamente. Cada diseño se tatúa una sola vez.
      </p>
    </div>
    <FlashCatalog client:load />
  </section>
</BaseLayout>
