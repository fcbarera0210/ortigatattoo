DATABASE_URL=postgresql://user:password@host/db?sslmode=require
AUTH_SECRET=change-me-to-a-random-32-char-string
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me
PUBLIC_BUSINESS_SLUG=ortiga-tattoo
# Store id (required). On Vercel, OIDC uses this with VERCEL_OIDC_TOKEN.
BLOB_STORE_ID_STORE_ID=store_...
# Optional local/static RW token (must start with vercel_blob_rw_).
# Do NOT put the webhook PEM key here — that is not an upload credential.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Optional: webhook verification key (not used for put/del uploads)
# BLOB_STORE_ID_WEBHOOK_PUBLIC_KEY=...
